# Creator Tools Environment Configuration
# Copy this file to .env and fill in your values

# App Configuration
APP_NAME=Creator Tools
APP_VERSION=1.0.0

# AdMob Configuration (Free tier rewarded ads)
ANDROID_ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
IOS_ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
REWARDED_AD_UNIT_ID=ca-app-pub-3940256099942544/5224354917

# DNS Configuration
DEFAULT_DNS_PROVIDER=adguard
SESSION_DURATION_HOURS=6
MAX_FREE_DAILY_SESSIONS=2

# Premium Configuration
PREMIUM_MONTHLY_PRICE=2.99
PREMIUM_YEARLY_PRICE=19.99

# Feature Flags
ENABLE_REWARDED_ADS=true
ENABLE_PREMIUM=true
ENABLE_QUICK_SETTINGS_TILE=true
ENABLE_NOTIFICATIONS=true

# API Endpoints (for update checks)
UPDATE_CHECK_URL=https://api.creatortools.app/v1/check-update
PRIVACY_POLICY_URL=https://creatortools.app/privacy
TERMS_URL=https://creatortools.app/terms
